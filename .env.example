# Server configuration
PORT=5000

# URL of the frontend — CORS is locked to this origin
CLIENT_URL=http://localhost:3000

# MongoDB connection string
DB_URL=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Cloudinary (image hosting)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe secret key (server-side only — never expose to the client)
STRIPE_SECRET_KEY=sk_test_xxx

# Admin key required (x-admin-key header) for all write routes:
# POST/PUT/DELETE on /api/products and /api/categories.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_long_random_admin_key
